g.EX={ALREADY_PINNED_ON_A_DEVICE:"\u062a\u0645 \u062a\u0646\u0632\u064a\u0644 \u0647\u0630\u0627 \u0627\u0644\u0641\u064a\u062f\u064a\u0648 \u0639\u0644\u0649 \u0627\u0644\u062d\u062f \u0627\u0644\u0623\u0642\u0635\u0649 \u0645\u0646 \u0639\u062f\u062f \u0627\u0644\u0623\u062c\u0647\u0632\u0629 \u0627\u0644\u0630\u064a \u064a\u0633\u0645\u062d \u0628\u0647 \u0635\u0627\u062d\u0628 \u062d\u0642\u0648\u0642 \u0627\u0644\u0637\u0628\u0639 \u0648\u0627\u0644\u0646\u0634\u0631. \u0644\u062a\u062a\u0645\u0643\u0646 \u0645\u0646 \u062a\u0634\u063a\u064a\u0644 \u0627\u0644\u0641\u064a\u062f\u064a\u0648 \u0647\u0646\u0627\u060c \u064a\u062c\u0628 \u0625\u0632\u0627\u0644\u0629 \u062a\u062b\u0628\u064a\u062a\u0647 \u0645\u0646 \u062c\u0647\u0627\u0632 \u0622\u062e\u0631.",DEVICE_FALLBACK:"\u0639\u0630\u0631\u064b\u0627\u060c \u0625\u0646 \u0647\u0630\u0627 \u0627\u0644\u0641\u064a\u062f\u064a\u0648 \u063a\u064a\u0631 \u0645\u062a\u0627\u062d \u0639\u0644\u0649 \u0647\u0630\u0627 \u0627\u0644\u062c\u0647\u0627\u0632.",
GENERIC_WITH_LINK_AND_CPN:"\u062d\u062f\u062b \u062e\u0637\u0623. \u064a\u064f\u0631\u062c\u0649 \u0625\u0639\u0627\u062f\u0629 \u0627\u0644\u0645\u062d\u0627\u0648\u0644\u0629 \u0644\u0627\u062d\u0642\u064b\u0627. (\u0631\u0642\u0645 \u062a\u0639\u0631\u064a\u0641 \u0627\u0644\u062a\u0634\u063a\u064a\u0644: $CPN) $BEGIN_LINK\u0645\u0632\u064a\u062f \u0645\u0646 \u0627\u0644\u0645\u0639\u0644\u0648\u0645\u0627\u062a$END_LINK",LICENSE:"\u0639\u0630\u0631\u064b\u0627\u060c \u062d\u062f\u062b \u062e\u0637\u0623 \u0641\u064a \u062a\u0631\u062e\u064a\u0635 \u0647\u0630\u0627 \u0627\u0644\u0641\u064a\u062f\u064a\u0648.",
VIDEO_UNAVAILABLE:"\u0627\u0644\u0641\u064a\u062f\u064a\u0648 \u063a\u064a\u0631 \u0645\u062a\u0627\u062d",FORMAT_UNAVAILABLE:"\u0644\u0627 \u064a\u062a\u0648\u0641\u0651\u0631 \u0647\u0630\u0627 \u0627\u0644\u0641\u064a\u062f\u064a\u0648 \u0628\u0627\u0644\u062c\u0648\u062f\u0629 \u0627\u0644\u0645\u0637\u0644\u0648\u0628\u0629. \u064a\u064f\u0631\u062c\u0649 \u0625\u0639\u0627\u062f\u0629 \u0627\u0644\u0645\u062d\u0627\u0648\u0644\u0629 \u0644\u0627\u062d\u0642\u064b\u0627.",GEO_FAILURE:"\u0647\u0630\u0627 \u0627\u0644\u0641\u064a\u062f\u064a\u0648 \u063a\u064a\u0631 \u0645\u062a\u0627\u062d \u0641\u064a \u0628\u0644\u062f\u0643.",
HTML5_AUDIO_RENDERER_ERROR:"\u062d\u062f\u062b \u062e\u0637\u0623 \u0641\u064a \u062a\u0634\u063a\u064a\u0644 \u0627\u0644\u0635\u0648\u062a. \u064a\u064f\u0631\u062c\u0649 \u0625\u0639\u0627\u062f\u0629 \u062a\u0634\u063a\u064a\u0644 \u062c\u0647\u0627\u0632 \u0627\u0644\u0643\u0645\u0628\u064a\u0648\u062a\u0631.",GENERIC_WITHOUT_LINK:"\u062d\u062f\u062b \u062e\u0637\u0623. \u064a\u064f\u0631\u062c\u0649 \u0627\u0644\u0645\u062d\u0627\u0648\u0644\u0629 \u0645\u062c\u062f\u062f\u064b\u0627 \u0641\u064a \u0648\u0642\u062a \u0644\u0627\u062d\u0642.",
HTML5_NO_AVAILABLE_FORMATS_FALLBACK:"\u062a\u0646\u0633\u064a\u0642 \u0627\u0644\u0641\u064a\u062f\u064a\u0648 \u0647\u0630\u0627 \u063a\u064a\u0631 \u0645\u062a\u0648\u0627\u0641\u0642.",HTML5_NO_AVAILABLE_FORMATS_FALLBACK_WITH_LINK:"\u0644\u0627 \u064a\u062f\u0639\u0645 \u0627\u0644\u0645\u062a\u0635\u0641\u062d \u0627\u0644\u0630\u064a \u062a\u0633\u062a\u062e\u062f\u0645\u0647 \u0623\u064a\u064b\u0627 \u0645\u0646 \u062a\u0646\u0633\u064a\u0642\u0627\u062a \u0627\u0644\u0641\u064a\u062f\u064a\u0648 \u0627\u0644\u0645\u062a\u0648\u0641\u0631\u0629 \u062d\u0627\u0644\u064a\u064b\u0627. $BEGIN_LINK\u0627\u0646\u0642\u0631 \u0647\u0646\u0627 \u0644\u0644\u0627\u0646\u062a\u0642\u0627\u0644 \u0625\u0644\u0649 \u0627\u0644\u0623\u0633\u0626\u0644\u0629 \u0627\u0644\u0634\u0627\u0626\u0639\u0629 \u0639\u0646 \u0641\u064a\u062f\u064a\u0648 HTML5.\u200f$END_LINK",
HTML5_NO_AVAILABLE_FORMATS_FALLBACK_WITH_LINK_SHORT:"\u0644\u0627 \u064a\u0645\u0643\u0646 \u0644\u0644\u0645\u062a\u0635\u0641\u0651\u062d \u0627\u0644\u062e\u0627\u0635 \u0628\u0643 \u062a\u0634\u063a\u064a\u0644 \u0647\u0630\u0627 \u0627\u0644\u0641\u064a\u062f\u064a\u0648. $BEGIN_LINK\u0645\u0632\u064a\u062f \u0645\u0646 \u0627\u0644\u0645\u0639\u0644\u0648\u0645\u0627\u062a$END_LINK",HTML5_SPS_UMP_STATUS_REJECTED:"\u062d\u062f\u062b \u062e\u0637\u0623. \u064a\u064f\u0631\u062c\u0649 \u0625\u0639\u0627\u062f\u0629 \u062a\u062d\u0645\u064a\u0644 \u0627\u0644\u0635\u0641\u062d\u0629 \u0623\u0648 \u0627\u0644\u0645\u062d\u0627\u0648\u0644\u0629 \u0644\u0627\u062d\u0642\u064b\u0627. $BEGIN_LINK\u0645\u0632\u064a\u062f \u0645\u0646 \u0627\u0644\u0645\u0639\u0644\u0648\u0645\u0627\u062a$END_LINK",
INVALID_DRM_MESSAGE:"\u0627\u0644\u0631\u0633\u0627\u0644\u0629 \u0627\u0644\u0645\u062a\u0639\u0644\u0642\u0629 \u0628\u0646\u0638\u0627\u0645 \u0625\u062f\u0627\u0631\u0629 \u0627\u0644\u062d\u0642\u0648\u0642 \u0627\u0644\u0631\u0642\u0645\u064a\u0629 (DRM) \u063a\u064a\u0631 \u0635\u0627\u0644\u062d\u0629.",PURCHASE_NOT_FOUND:"\u064a\u062c\u0628 \u0634\u0631\u0627\u0621 \u0647\u0630\u0627 \u0627\u0644\u0641\u064a\u062f\u064a\u0648 \u0644\u0645\u0634\u0627\u0647\u062f\u062a\u0647.",PURCHASE_REFUNDED:"\u062a\u0645 \u0631\u062f \u0627\u0644\u0623\u0645\u0648\u0627\u0644 \u0627\u0644\u0645\u062f\u0641\u0648\u0639\u0629 \u0644\u0634\u0631\u0627\u0621 \u0647\u0630\u0627 \u0627\u0644\u0641\u064a\u062f\u064a\u0648.",
RENTAL_EXPIRED:"\u0627\u0646\u062a\u0647\u062a \u0635\u0644\u0627\u062d\u064a\u0629 \u062a\u0623\u062c\u064a\u0631 \u0647\u0630\u0627 \u0627\u0644\u0641\u064a\u062f\u064a\u0648.",CAST_SESSION_DEVICE_MISMATCHED:"\u0644\u0627 \u064a\u062a\u0637\u0627\u0628\u0642 \u0627\u0644\u062c\u0647\u0627\u0632 \u0641\u064a \u062c\u0644\u0633\u0629 \u0627\u0644\u0628\u062b \u0645\u0639 \u0627\u0644\u062c\u0647\u0627\u0632 \u0627\u0644\u0645\u0637\u0644\u0648\u0628.",CAST_SESSION_VIDEO_MISMATCHED:"\u0644\u0627 \u064a\u062a\u0637\u0627\u0628\u0642 \u0627\u0644\u0641\u064a\u062f\u064a\u0648 \u0641\u064a \u062c\u0644\u0633\u0629 \u0627\u0644\u0628\u062b \u0645\u0639 \u0627\u0644\u0641\u064a\u062f\u064a\u0648 \u0627\u0644\u0645\u0637\u0644\u0648\u0628.",
CAST_TOKEN_FAILED:"\u062c\u0644\u0633\u0629 \u0627\u0644\u0628\u062b \u063a\u064a\u0631 \u0645\u062a\u0627\u062d\u0629. \u064a\u0631\u062c\u0649 \u0625\u0639\u0627\u062f\u0629 \u062a\u062d\u0645\u064a\u0644 \u0627\u0644\u0635\u0641\u062d\u0629 \u0623\u0648 \u0625\u0639\u0627\u062f\u0629 \u0627\u0644\u0645\u062d\u0627\u0648\u0644\u0629 \u0644\u0627\u062d\u0642\u064b\u0627.",CAST_TOKEN_EXPIRED:"\u0627\u0646\u062a\u0647\u062a \u0635\u0644\u0627\u062d\u064a\u0629 \u062c\u0644\u0633\u0629 \u0627\u0644\u0628\u062b. \u064a\u0631\u062c\u0649 \u0625\u0639\u0627\u062f\u0629 \u062a\u062d\u0645\u064a\u0644 \u0627\u0644\u0635\u0641\u062d\u0629.",
CAST_TOKEN_MALFORMED:"\u062c\u0644\u0633\u0629 \u0627\u0644\u0628\u062b \u063a\u064a\u0631 \u0635\u0627\u0644\u062d\u0629. \u064a\u0631\u062c\u0649 \u0625\u0639\u0627\u062f\u0629 \u062a\u062d\u0645\u064a\u0644 \u0627\u0644\u0635\u0641\u062d\u0629 \u0623\u0648 \u0625\u0639\u0627\u062f\u0629 \u0627\u0644\u0645\u062d\u0627\u0648\u0644\u0629 \u0644\u0627\u062d\u0642\u064b\u0627.",SERVER_ERROR:"\u062d\u062f\u062b \u062e\u0637\u0623 \u062f\u0627\u062e\u0644\u064a \u0641\u064a \u0627\u0644\u062e\u0627\u062f\u0645. \u064a\u0631\u062c\u0649 \u0625\u0639\u0627\u062f\u0629 \u0627\u0644\u0645\u062d\u0627\u0648\u0644\u0629 \u0644\u0627\u062d\u0642\u064b\u0627.",
STOPPED_BY_ANOTHER_PLAYBACK:"\u064a\u0634\u063a\u0651\u0644 \u062d\u0633\u0627\u0628\u0643 \u0647\u0630\u0627 \u0627\u0644\u0641\u064a\u062f\u064a\u0648 \u0641\u064a \u0645\u0648\u0642\u0639 \u0622\u062e\u0631. \u064a\u064f\u0631\u062c\u0649 \u0625\u0639\u0627\u062f\u0629 \u062a\u062d\u0645\u064a\u0644 \u0647\u0630\u0647 \u0627\u0644\u0635\u0641\u062d\u0629 \u0644\u0627\u0633\u062a\u0626\u0646\u0627\u0641 \u0627\u0644\u0645\u0634\u0627\u0647\u062f\u0629.",STREAM_LICENSE_NOT_FOUND:"\u062a\u0645 \u0625\u064a\u0642\u0627\u0641 \u062a\u0634\u063a\u064a\u0644 \u0627\u0644\u0641\u064a\u062f\u064a\u0648. \u064a\u0631\u062c\u0649 \u0627\u0644\u0645\u062d\u0627\u0648\u0644\u0629 \u0645\u0646 \u062c\u062f\u064a\u062f.",
STREAMING_DEVICES_QUOTA_PER_24H_EXCEEDED:"\u062a\u0645 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0639\u062f\u062f \u0643\u062b\u064a\u0631 \u062c\u062f\u064b\u0627 \u0645\u0646 \u0627\u0644\u0623\u062c\u0647\u0632\u0629/\u0639\u0646\u0627\u0648\u064a\u0646 IP \u0641\u064a \u063a\u0636\u0648\u0646 24 \u0633\u0627\u0639\u0629.",STREAMING_NOT_ALLOWED:"\u0644\u0627 \u064a\u064f\u0633\u0645\u062d \u0628\u062a\u0634\u063a\u064a\u0644 \u0647\u0630\u0627 \u0627\u0644\u0641\u064a\u062f\u064a\u0648 \u0644\u0623\u0646\u0647 \u0645\u064f\u062b\u0628\u062a \u0639\u0644\u0649 \u062c\u0647\u0627\u0632 \u0622\u062e\u0631.",
RETRYABLE_ERROR:"\u062d\u062f\u062b \u062e\u0637\u0623 \u0645\u0624\u0642\u062a \u0641\u064a \u0627\u0644\u062e\u0627\u062f\u0645. \u064a\u0631\u062c\u0649 \u0625\u0639\u0627\u062f\u0629 \u0627\u0644\u0645\u062d\u0627\u0648\u0644\u0629 \u0644\u0627\u062d\u0642\u064b\u0627.",TOO_MANY_REQUESTS:"\u064a\u064f\u0631\u062c\u0649 \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644 \u0644\u0645\u0634\u0627\u0647\u062f\u0629 \u0647\u0630\u0627 \u0627\u0644\u0641\u064a\u062f\u064a\u0648.",TOO_MANY_REQUESTS_WITH_LINK:"\u064a\u064f\u0631\u062c\u0649$BEGIN_LINK\u0627\u0644\u0646\u0642\u0631 \u0647\u0646\u0627$END_LINK \u0644\u0645\u0634\u0627\u0647\u062f\u0629 \u0647\u0630\u0627 \u0627\u0644\u0641\u064a\u062f\u064a\u0648 \u0639\u0644\u0649 YouTube.",
TOO_MANY_STREAMS_PER_USER:"\u062a\u0648\u0642\u0641 \u0627\u0644\u062a\u0634\u063a\u064a\u0644 \u0628\u0633\u0628\u0628 \u0639\u0631\u0636 \u0639\u062f\u062f \u0643\u062b\u064a\u0631 \u062c\u062f\u064b\u0627 \u0645\u0646 \u0627\u0644\u0641\u064a\u062f\u064a\u0648\u0647\u0627\u062a \u0627\u0644\u062a\u0627\u0628\u0639\u0629 \u0644\u0644\u062d\u0633\u0627\u0628 \u0646\u0641\u0633\u0647.",TOO_MANY_STREAMS_PER_ENTITLEMENT:"\u062a\u0648\u0642\u0641 \u0627\u0644\u062a\u0634\u063a\u064a\u0644 \u0628\u0633\u0628\u0628 \u0639\u0631\u0636 \u0647\u0630\u0627 \u0627\u0644\u0641\u064a\u062f\u064a\u0648 \u0639\u0644\u0649 \u0639\u062f\u062f \u0643\u062b\u064a\u0631 \u062c\u062f\u064b\u0627 \u0645\u0646 \u0627\u0644\u0623\u062c\u0647\u0632\u0629.",
UNSUPPORTED_DEVICE:"\u0644\u0627 \u064a\u0639\u062a\u0645\u062f \u0647\u0630\u0627 \u0627\u0644\u062c\u0647\u0627\u0632 \u0625\u0645\u0643\u0627\u0646\u064a\u0629 \u062a\u0634\u063a\u064a\u0644 \u0627\u0644\u0641\u064a\u062f\u064a\u0648.",VIDEO_FORBIDDEN:"\u062a\u0645 \u062d\u0638\u0631 \u0627\u0644\u0648\u0635\u0648\u0644 \u0625\u0644\u0649 \u0647\u0630\u0627 \u0627\u0644\u0641\u064a\u062f\u064a\u0648.",VIDEO_NOT_FOUND:"\u062a\u0639\u0630\u0631 \u0627\u0644\u0639\u062b\u0648\u0631 \u0639\u0644\u0649 \u0647\u0630\u0627 \u0627\u0644\u0641\u064a\u062f\u064a\u0648.",
